{
  "$comment": "SINGLE SOURCE OF TRUTH for design scales, token names, and lint rules. Consumed by scripts/lint-classes.mjs (scale + banned classes) and the Storybook Foundations page (names + scales). Color VALUES live in src/theme/lahzo.css; this file lists names + roles only, so values are never duplicated.",
  "themes": ["lahzo-light", "lahzo-dark"],
  "spacingPx": [4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80, 96],
  "controlHeightsPx": { "xs": 24, "sm": 32, "md": 40, "lg": 48 },
  "iconSizesPx": [16, 20, 24, 32],
  "colorTokens": [
    { "name": "base-100", "role": "Page background" },
    { "name": "base-200", "role": "Cards, inputs, elevated surfaces" },
    { "name": "base-300", "role": "Borders, dividers" },
    { "name": "base-content", "role": "Default text" },
    { "name": "primary", "role": "Brand, primary actions, focus rings" },
    { "name": "secondary", "role": "Quiet secondary actions" },
    { "name": "accent", "role": "Decorative accents" },
    { "name": "neutral", "role": "High-emphasis dark UI, tooltips" },
    { "name": "info", "role": "Informational" },
    { "name": "success", "role": "Success" },
    { "name": "warning", "role": "Warning" },
    { "name": "error", "role": "Error / danger" }
  ],
  "typeStyles": [
    { "name": "text-display-lg", "role": "Hero / page display" },
    { "name": "text-display", "role": "Section display" },
    { "name": "text-h1", "role": "Screen title (one per screen)" },
    { "name": "text-h2", "role": "Card / modal title" },
    { "name": "text-h3", "role": "Content / sub-card title" },
    { "name": "text-body-lg", "role": "Lead paragraph" },
    { "name": "text-body", "role": "Default body, menu items, cells" },
    { "name": "text-button", "role": "Control labels, nav tabs, field labels" },
    { "name": "text-caption", "role": "Metadata, timestamps, IDs, hints" },
    { "name": "text-label", "role": "UI tags, section headers" },
    { "name": "btn-link", "role": "Links (the only underlined style)" }
  ],
  "bannedClasses": ["btn-soft", "btn-dash", "btn-accent", "btn-info", "btn-warning", "btn-outline", "btn-neutral"]
}
